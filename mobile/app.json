{
  "expo": {
    "name": "PocketCode",
    "slug": "pocketcode",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#07080c",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan the QR code printed by the PocketCode CLI to connect."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07080c",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": ["CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Scan the QR code printed by the PocketCode CLI to connect."
        }
      ]
    ]
  }
}
